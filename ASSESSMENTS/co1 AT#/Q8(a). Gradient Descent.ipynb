      "cell_type": "code",
      "source": [
        "x = 5\n",
        "lr = 0.1\n",
        "\n",
        "for i in range(5):\n",
        "    grad = 2 * x\n",
        "    x = x - lr * grad\n",
        "    print(\"Iteration\", i+1, \":\", round(x,2))"
      ],
