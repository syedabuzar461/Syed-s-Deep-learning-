        "import numpy as np\n",
        "\n",
        "data = np.arange(20)\n",
        "batch_size = 5\n",
        "\n",
        "for i in range(0, len(data), batch_size):\n",
        "    print(\"Batch:\", data[i:i+batch_size])"
