      "source": [
        "import numpy as np\n",
        "\n",
        "for d in [2, 5, 10, 20]:\n",
        "    data = np.random.rand(100, d)\n",
        "    dist = np.mean(np.linalg.norm(data[1:] - data[:-1], axis=1))\n",
        "    print(\"Dimension:\", d, \"Average Distance:\", round(dist,2))"
      ],
