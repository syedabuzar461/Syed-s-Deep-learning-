      "source": [
        "from sklearn.linear_model import SGDRegressor\n",
        "import numpy as np\n",
        "\n",
        "X = np.array([[1],[2],[3],[4],[5]])\n",
        "y = np.array([2,4,6,8,10])\n",
        "\n",
        "model = SGDRegressor(max_iter=1000, random_state=1)\n",
        "model.fit(X, y)\n",
        "\n",
        "print(\"Prediction =\", model.predict([[6]]))"
      ],
