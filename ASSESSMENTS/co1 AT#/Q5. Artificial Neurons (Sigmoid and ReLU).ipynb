      "source": [
        "import numpy as np\n",
        "\n",
        "x = np.array([-2, -1, 0, 1, 2])\n",
        "\n",
        "sigmoid = 1 / (1 + np.exp(-x))\n",
        "relu = np.maximum(0, x)\n",
        "\n",
        "print(\"Input :\", x)\n",
        "print(\"Sigmoid :\", sigmoid)\n",
        "print(\"ReLU :\", relu)"
      ],
